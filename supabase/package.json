    "supabase:stop": "supabase stop"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.28.0",
    "@supabase/supabase-js": "^2.100.1",
    "hono": "^4.12.9",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@modelcontextprotocol/inspector": "^0.14.0",
    "typescript": "^5.8.3"
  }
}
