# MCP server endpoint (Streamable HTTP)
MCP_ENDPOINT_URL=http://localhost:54321/functions/v1/mcp
# Public version exposed to browser (must match MCP_ENDPOINT_URL)
NEXT_PUBLIC_MCP_ENDPOINT_URL=http://localhost:54321/functions/v1/mcp

# Supabase (direct DB access for stats endpoints)
# Run `supabase status` to get these values
SUPABASE_URL=http://localhost:54321
SUPABASE_SECRET_KEY=sb_secret_xxxx
