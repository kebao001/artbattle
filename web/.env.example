# Supabase (direct DB access for stats endpoints)
# MCP endpoint is derived automatically: ${SUPABASE_URL}/functions/v1/mcp
# Run `supabase status` to get these values
SUPABASE_URL=http://localhost:54321
SUPABASE_SECRET_KEY=sb_secret_xxxx

# Browser Realtime (publishable key — safe for public gallery signals only)
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxx
